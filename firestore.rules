rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to get user role
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    // Helper function to check if user is admin
    function isAdmin() {
      return isAuthenticated() && getUserRole() in ['ADMIN', 'MASTER_ADMIN'];
    }
    
    // Helper function to check if user is master admin
    function isMasterAdmin() {
      return isAuthenticated() && getUserRole() == 'MASTER_ADMIN';
    }
    
    // USERS COLLECTION
    match /users/{userId} {
      // Anyone authenticated can read user profiles (for staff directory)
      allow read: if isAuthenticated();
      
      // Users can update their own profile, admins can update anyone
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // Only master admins can create/delete users
      allow create, delete: if isMasterAdmin();
    }
    
    // CLIENTS COLLECTION
    match /clients/{clientId} {
      // All authenticated users can read clients (for dropdown selection)
      allow read: if isAuthenticated();
      
      // Only admins can create, update, or delete clients
      allow create, update, delete: if isAdmin();
    }
    
    // TASKS COLLECTION
    match /tasks/{taskId} {
      // All authenticated users can read tasks
      allow read: if isAuthenticated();
      
      // Users can create tasks
      allow create: if isAuthenticated();
      
      // Users can update tasks ONLY if they are assigned to it or are Admin
      // Removed 'createdBy' permission to enforce strict assignment-based editing
      allow update: if isAuthenticated() && (
        request.auth.uid in resource.data.assignedTo ||
        isAdmin()
      );
      
      // Only admins can delete tasks
      allow delete: if isAdmin();
    }
    
    // ATTENDANCE COLLECTION
    match /attendance/{attendanceId} {
      // Users can read their own attendance, admins can read all
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.userId ||
        isAdmin()
      );
      
      // Users can create/update their own attendance, Admins can do for anyone
      allow create, update: if isAuthenticated() && (
        request.auth.uid == request.resource.data.userId ||
        isAdmin()
      );
      
      // Only admins can delete attendance records
      allow delete: if isAdmin();
    }
    
    // LEAVE REQUESTS COLLECTION
    match /leaves/{leaveId} {
      // Users can read their own leave requests, admins can read all
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.userId ||
        isAdmin()
      );
      
      // Users can create their own leave requests
      allow create: if isAuthenticated();
      
      // Users can update their own pending requests, admins can update any
      allow update: if isAuthenticated() && (
        (request.auth.uid == resource.data.userId && resource.data.status == 'PENDING') ||
        isAdmin()
      );
      
      // Only the user or admins can delete leave requests
      allow delete: if isAuthenticated() && (
        request.auth.uid == resource.data.userId ||
        isAdmin()
      );
    }

    // NOTIFICATIONS COLLECTION
    match /notifications/{notificationId} {
        // Users can read/delete their own notifications
        allow read, delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
        // Anyone (system/users) can create notifications for others
        allow create: if isAuthenticated();
        // Users can update (mark as read) their own notifications
        allow update: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    
    // TEMPLATES (Advanced)
    match /templates/{templateId} {
      allow read: if isAuthenticated();
      // Allow creation/update by any auth user (or restrict to Admin if preferred)
      allow create, update: if isAuthenticated();
      allow delete: if isAuthenticated() && (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    // TASK TEMPLATES (Simple)
    match /task_templates/{templateId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
    
    // WORKFLOWS
    match /workflows/{workflowId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
    
    // =============================================
    // ADVANCED FEATURES COLLECTIONS
    // =============================================
    
    // TIME TRACKING
    match /timeEntries/{entryId} {
      // Users can read their own entries, admins can read all
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.userId ||
        isAdmin()
      );
      
      // Users can create/update their own entries
      allow create, update: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      
      // Only admins can delete entries
      allow delete: if isAdmin();
    }
    
    // CHAT CHANNELS - Admin-only creation, member-based read access
    match /chatChannels/{channelId} {
      // Anyone can read channels they're a member of
      allow read: if isAuthenticated() && 
        request.auth.uid in resource.data.members;
      
      // Only admins can create channels
      allow create: if isAdmin();
      
      // Only admins can update or delete channels
      // Allow members to update ONLY if adding themselves (joining) - omitted for now as logic is complex
      allow update, delete: if isAdmin();
    }
    
    // CHAT MESSAGES - Members can read/write in their channels
    match /chatMessages/{messageId} {
      // Can read messages from channels you're a member of
      // Note: This requires a get() call which costs 1 read. 
      allow read: if isAuthenticated() && 
        request.auth.uid in get(/databases/$(database)/documents/chatChannels/$(resource.data.channelId)).data.members;
      
      // Can create messages in channels you're a member of
      allow create: if isAuthenticated() && 
        request.auth.uid in get(/databases/$(database)/documents/chatChannels/$(request.resource.data.channelId)).data.members;
      
      // Can only update your own messages (for read receipts)
      allow update: if isAuthenticated() && 
        request.auth.uid == resource.data.senderId;
      
      // Can only delete your own messages
      allow delete: if isAuthenticated() && 
        request.auth.uid == resource.data.senderId;
    }
    
    // COMPLIANCE EVENTS
    match /complianceEvents/{eventId} {
      // All authenticated users can read
      allow read: if isAuthenticated();
      
      // Only admins can create, update, or delete
      allow create, update, delete: if isAdmin();
    }
    
    // TEMPLATES (Corrected collection name)
    match /task_templates/{templateId} {
      // All authenticated users can read templates
      allow read: if isAuthenticated();
      
      // Only admins can create, update, or delete
      allow create, update, delete: if isAdmin();
    }
    
    // WORKFLOWS
    match /workflows/{workflowId} {
      // All authenticated users can read workflows
      allow read: if isAuthenticated();
      
      // Only admins can create, update, or delete
      allow create, update, delete: if isAdmin();
    }
    
    // KNOWLEDGE BASE (Resources)
    match /knowledge_base/{resourceId} {
      // All authenticated users can read
      allow read: if isAuthenticated();
      
      // Admins and Managers can create, update, or delete
      allow create, update, delete: if isAdmin() || (isAuthenticated() && getUserRole() == 'MANAGER');
    }

    // EVENTS (Consolidated Rule)
    match /events/{eventId} {
      // All authenticated users can read events
      allow read: if isAuthenticated();
      
      // Authenticated users can create events
      allow create: if isAuthenticated();
      
      // Creators can update/delete their own events, Admins can do anything
      allow update, delete: if isAuthenticated() && (
        resource.data.createdBy == request.auth.uid || 
        isAdmin()
      );
    }

    // RESOURCES COLLECTION
    match /resources/{resourceId} {
      // All authenticated users can read resources
      allow read: if isAuthenticated();
      
      // Admins and Managers can create, update, or delete
      // Using a custom check for Manager if needed, or just isAdmin() for now
      allow create, update, delete: if isAdmin() || (isAuthenticated() && getUserRole() == 'MANAGER');
    }
  }
}
