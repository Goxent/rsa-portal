rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // HELPERS
    function getUserRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role : 'STAFF';
    }
    
    function isAdmin() {
      return isAuthenticated() && (getUserRole() == 'ADMIN' || getUserRole() == 'MASTER_ADMIN');
    }

    // Security & Validation Helpers
    function isString(val) { return val is string; }
    function isSafeString(val, maxLen) { return isString(val) && val.size() <= maxLen; }
    function checkKeys(requiredKeys) { return request.resource.data.keys().hasAll(requiredKeys); }

    // Returns true for admins, managers, or users granted explicit task-creation authorization
    function canCreateTask() {
      return isAuthenticated() && (
        getUserRole() == 'ADMIN' ||
        getUserRole() == 'MASTER_ADMIN' ||
        getUserRole() == 'MANAGER' ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('taskCreationAuthorized', false) == true
        )
      );
    }

    // AUDIT LOGS - Only admins can read, authenticated users can write (logging)
    match /auditLogs/{logId} {
      allow read: if isAuthenticated() && (getUserRole() == 'ADMIN' || getUserRole() == 'MASTER_ADMIN');
      allow create: if isAuthenticated();
      allow update, delete: if false; // Audit logs are immutable
    }

    // USERS COLLECTION
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      // Allow deletion by MASTER_ADMIN, or allow migration flow to clean up pending_ or invited_ placeholders
      allow delete: if isAuthenticated() && (getUserRole() == 'MASTER_ADMIN' || userId.matches('^pending_.*') || userId.matches('^invited_.*'));

      // Allow users to manage their own settings (like dashboard layout)
      match /settings/{settingId} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }
    }

    // STAFF ALLOWLIST — Used before auth account is created
    match /staffAllowlist/{email} {
      allow read: if isAuthenticated(); // Restrict to authenticated users for discovery protection
      allow create, update, delete: if isAdmin();
    }
    
    // CLIENTS COLLECTION
    match /clients/{clientId} {
      allow read: if isAuthenticated();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isAuthenticated() && request.auth.uid in resource.data.get('permittedStaff', []));
    }

    // ATTENDANCE COLLECTION
    match /attendance/{attendanceId} {
      allow read: if isAuthenticated();
      // Enforce schema on create
      allow create: if isAuthenticated() && (request.auth.uid == request.resource.data.userId || isAdmin())
                    && checkKeys(['userId', 'date', 'status'])
                    && isSafeString(request.resource.data.userId, 128);
      allow update: if isAuthenticated() && (request.auth.uid == request.resource.data.userId || isAdmin());
      allow delete: if isAdmin();
    }

    // ATTENDANCE REQUESTS COLLECTION
    match /attendanceRequests/{requestId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isAdmin();
    }
    
    // LEAVE REQUESTS COLLECTION
    match /leaves/{leaveId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && ((request.auth.uid == resource.data.userId && resource.data.status == 'PENDING') || isAdmin());
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    // TASKS COLLECTION
    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      
      allow update: if isAuthenticated() && (
        request.auth.uid in resource.data.assignedTo ||
        resource.data.createdBy == request.auth.uid ||
        request.auth.uid == resource.data.get('teamLeaderId', '') ||
        isAdmin() ||
        getUserRole() == 'MANAGER'
      ) && (
        // 1. ARCHIVED LOCKDOWN: Archived tasks cannot be edited by ANYONE (even Admins)
        // This ensures the total integrity of historical audit documentation.
        resource.data.get('status', '') != 'ARCHIVED'
      ) && (
        // 2. GOVERNANCE LOCKDOWN: Completed tasks in Review & Conclusion can only be reopened/modified by Admin
        (!(resource.data.status == 'COMPLETED' && resource.data.auditPhase == 'REVIEW_AND_CONCLUSION' && request.resource.data.status != 'COMPLETED') || isAdmin())
      ) && (
        // 3. SIGN-OFF PROTECTION: Only designated roles or Admins can sign off
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['teamLeadApprovedAt'])) ||
        (request.auth.uid == resource.data.get('teamLeaderId', '') || isAdmin())
      ) && (
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['engagementReviewerApprovedAt'])) ||
        (request.auth.uid == resource.data.get('engagementReviewerId', '') || isAdmin())
      ) && (
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['signingPartnerApprovedAt'])) ||
        (request.auth.uid == resource.data.get('signingPartnerId', '') || isAdmin())
      ) && (
        // 4. COMPLETION GATE: Enforce sign-offs before status becomes COMPLETED (Admins can bypass)
        (request.resource.data.get('status', '') != 'COMPLETED') ||
        (isAdmin() || (
            resource.data.get('teamLeadApprovedAt', '') != '' &&
            resource.data.get('engagementReviewerApprovedAt', '') != '' &&
            resource.data.get('signingPartnerApprovedAt', '') != ''
        ))
      );
      
      allow delete: if isAdmin();
    }

    // NOTIFICATIONS COLLECTION
    match /notifications/{notificationId} {
        allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.userId == 'ALL');
        allow create: if isAuthenticated();
        allow delete, update: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // NOTICES COLLECTION
    match /notices/{noticeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }
    
    // TEMPLATES (Advanced)
    match /templates/{templateId} {
      allow read: if isAuthenticated();
      // Allow creation/update by any auth user (or restrict to Admin if preferred)
      allow create, update: if isAuthenticated();
      allow delete: if isAuthenticated() && (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    // TASK TEMPLATES (Simple)
    // WORKFLOWS
    // Covered below in ADVANCED FEATURES COLLECTIONS
    
    // =============================================
    // ADVANCED FEATURES COLLECTIONS
    // =============================================
    
    // TIME TRACKING
    match /timeEntries/{entryId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
    }
    
    // CHAT CHANNELS - Admin-only creation, member-based read access
    match /chatChannels/{channelId} {
      // Anyone can read channels they're a member of
      allow read: if isAuthenticated() && 
        request.auth.uid in resource.data.members;
      
      // Only admins can create channels
      allow create: if isAdmin();
      
      // Only admins can update or delete channels
      // Allow members to update ONLY if adding themselves (joining) - omitted for now as logic is complex
      allow update, delete: if isAdmin();
    }
    
    // CHAT MESSAGES - Members can read/write in their channels
    match /chatMessages/{messageId} {
      // Can read messages from channels you're a member of
      // Note: This requires a get() call which costs 1 read. 
      allow read: if isAuthenticated() && 
        request.auth.uid in get(/databases/$(database)/documents/chatChannels/$(resource.data.channelId)).data.members;
      
      // Can create messages in channels you're a member of
      allow create: if isAuthenticated() && 
        request.auth.uid in get(/databases/$(database)/documents/chatChannels/$(request.resource.data.channelId)).data.members;
      
      // Can only update your own messages (for read receipts)
      allow update: if isAuthenticated() && 
        request.auth.uid == resource.data.senderId;
      
      // Can only delete your own messages
      allow delete: if isAuthenticated() && 
        request.auth.uid == resource.data.senderId;
    }
    
    // COMPLIANCE EVENTS
    match /complianceEvents/{eventId} {
      // All authenticated users can read
      allow read: if isAuthenticated();
      
      // Only admins can create, update, or delete
      allow create, update, delete: if isAdmin();
    }

    // SMART REMINDERS
    match /smart_reminders/{reminderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // REMINDER PREFERENCES
    match /reminder_preferences/{userId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }
    
    // TEMPLATES
    match /task_templates/{templateId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
    
    // TEMPLATE FOLDERS
    match /template_folders/{folderId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
    
    // WORKFLOWS
    match /workflows/{workflowId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
    
    // KNOWLEDGE BASE (Resources)
    match /knowledge_base/{resourceId} {
      // All authenticated users can read
      allow read: if isAuthenticated();
      
      // Admins and Managers can create, update, or delete
      allow create, update, delete: if isAdmin() || (isAuthenticated() && getUserRole() == 'MANAGER');
    }

    // EVENTS (Consolidated Rule)
    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (
        resource.data.createdBy == request.auth.uid || isAdmin()
      );
    }

    // RESOURCES COLLECTION
    match /resources/{resourceId} {
      // All authenticated users can read resources
      allow read: if isAuthenticated();
      
      // Admins and Managers can create, update, or delete
      // Admins and Managers can create, update, or delete
      // Using a custom check for Manager if needed, or just isAdmin() for now
      allow create, update, delete: if isAdmin() || (isAuthenticated() && getUserRole() == 'MANAGER');
    }

    // CATEGORIES COLLECTION
    match /resource_categories/{categoryId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // PERFORMANCE COLLECTIONS
    match /performance_cycles/{cycleId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /peer_reviews/{reviewId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // AUDIT DOCUMENTATION SYSTEM
    match /auditDocFiles/{fileId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /auditDocFolders/{folderId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }
  }
}
