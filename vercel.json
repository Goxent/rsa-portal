{
    "crons": [
        {
            "path": "/api/check-reminders",
            "schedule": "0 7 * * *"
        },
        {
            "path": "/api/cleanup-old-comments",
            "schedule": "0 2 * * *"
        },
        {
            "path": "/api/cleanup-audit-logs",
            "schedule": "0 3 * * *"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "X-XSS-Protection",
                    "value": "1; mode=block"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "strict-origin-when-cross-origin"
                },
                {
                    "key": "Permissions-Policy",
                    "value": "camera=(), microphone=(), geolocation=()"
                },
                {
                    "key": "Strict-Transport-Security",
                    "value": "max-age=63072000; includeSubDomains; preload"
                },
                {
                    "key": "Content-Security-Policy",
                    "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://apis.google.com https://www.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' 'unsafe-inline' https://fonts.gstatic.com https://at.alicdn.com data:; img-src 'self' data: https://firebasestorage.googleapis.com https://syd.cloud.appwrite.io https://www.gstatic.com https://cdn-icons-png.flaticon.com blob:; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com https://syd.cloud.appwrite.io wss://*.firebaseio.com wss://*.firebase.com https://api.anthropic.com https://api.resend.com; media-src 'self' data:; object-src 'none'; base-uri 'self';"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/((?!api/|assets/|sw\\.js|manifest\\.json|.*\\.(?:ico|png|svg|jpg)).*)",
            "destination": "/index.html"
        }
    ]
}